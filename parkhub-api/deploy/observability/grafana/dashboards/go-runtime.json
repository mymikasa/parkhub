{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "ParkHub Go runtime 指标：goroutine、memory、GC、GOMAXPROCS（基于 contrib/instrumentation/runtime 新版语义命名）",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "进程概览",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Goroutine 数量",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "go_goroutine_count{job=~\"$service\"}",
          "legendFormat": "goroutines",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "GOMAXPROCS",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "go_processor_limit{job=~\"$service\"}",
          "legendFormat": "procs",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 104857600 }, { "color": "red", "value": 524288000 }] },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "总内存使用",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "sum(go_memory_used_bytes{job=~\"$service\"})",
          "legendFormat": "memory",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "下次 GC 目标",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "go_memory_gc_goal_bytes{job=~\"$service\"}",
          "legendFormat": "gc goal",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "内存与 Goroutine",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "stacking": { "mode": "normal" } }, "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "内存使用趋势（按类型）",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "go_memory_used_bytes{job=~\"$service\"}",
          "legendFormat": "{{go_memory_type}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "go_memory_gc_goal_bytes{job=~\"$service\"}",
          "legendFormat": "gc goal",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 12,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Goroutine 趋势",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "go_goroutine_count{job=~\"$service\"}",
          "legendFormat": "goroutines",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20,
      "title": "分配与 GC",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1 }, "unit": "Bps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 21,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "内存分配速率",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "rate(go_memory_allocated_bytes_total{job=~\"$service\"}[$__rate_interval])",
          "legendFormat": "alloc B/s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1 }, "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 22,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "分配次数速率",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "rate(go_memory_allocations_total{job=~\"$service\"}[$__rate_interval])",
          "legendFormat": "allocs/s",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["parkhub", "go", "runtime"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "parkhub-monolith", "value": "parkhub-monolith" },
        "datasource": { "type": "prometheus", "uid": "victoriametrics" },
        "definition": "label_values(go_goroutine_count, job)",
        "hide": 0,
        "includeAll": false,
        "label": "服务",
        "multi": false,
        "name": "service",
        "options": [],
        "query": { "query": "label_values(go_goroutine_count, job)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "1m", "value": "1m" },
        "hide": 0,
        "includeAll": false,
        "label": "窗口",
        "multi": false,
        "name": "interval",
        "options": [
          { "selected": false, "text": "30s", "value": "30s" },
          { "selected": true, "text": "1m", "value": "1m" },
          { "selected": false, "text": "5m", "value": "5m" }
        ],
        "query": "30s,1m,5m",
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ParkHub - Go Runtime",
  "uid": "parkhub-go-runtime",
  "version": 2
}
